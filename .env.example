LOCK_TIME_MINUTES=15
ENABLE_AUDIT_LOG=true
LLM_MODEL=
LLM_CHAT_TEMPLATE=
LLM_CTX_SIZE=16384
LLM_GPU_LAYERS=
LLM_THREADS=
