# Copy to .env on the server and fill real values. Do not commit .env.
QUANTLAB_RUNTIME_DIR=/home/quantlab/quantlab-runtime
JWT_SECRET=
JWT_ALGORITHM=HS256
TOKEN_EXP_HOURS=8
COOKIE_NAME=quantlab_token
